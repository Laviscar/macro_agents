APP_ENV=dev
STORAGE_ROOT=./storage
KNOWLEDGE_ROOT=./knowledge
DEFAULT_REGION=Global
DEFAULT_THEME=macro_regime
FINNHUB_API_KEY=your_finnhub_api_key

# --- LLM configuration ---
# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Provider: openai | minimax | anthropic
LLM_PROVIDER=openai

# Model name served by your endpoint (examples; set to what your key supports)
LLM_MODEL=gpt-4o-mini

# Optional: override the API base URL (e.g. a proxy or MiniMax/OpenAI-compatible endpoint)
# LLM_BASE_URL=https://api.openai.com/v1

# API key. Either set the provider-default var below, or set LLM_API_KEY,
# or point LLM_API_KEY_ENV at a custom var name.
OPENAI_API_KEY=
# MINIMAX_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_API_KEY_ENV=MY_CUSTOM_KEY_VAR
# LLM_API_KEY=

# Optional request timeout (seconds)
# LLM_TIMEOUT_SECONDS=30

# Optional token budget per task (0 = unlimited). When > 0 and real tokens are
# metered from LLM calls, the harness stops the loop once the budget is exceeded.
# LLM_TOKEN_BUDGET=0

# --- Continuous run loop (run_loop.py) ---
# RUN_LOOP_TICK_SECONDS=30
# RUN_LOOP_INGEST_SECONDS=300          # 5 min
# RUN_LOOP_TRIAGE_SECONDS=900          # 15 min
# RUN_LOOP_ANALYSIS_SECONDS=900        # 15 min
# RUN_LOOP_CONSOLIDATION_SECONDS=3600  # 60 min
# RUN_LOOP_TRIAGE_BATCH=20
# RUN_LOOP_ANALYSIS_BATCH=10

# --- Three independently-keyed LLM tiers (each falls back to bare LLM_* when unset) ---
# Fill the same key in all three, or different keys/models/endpoints per tier.
# Triage (cheap importance screen):
# LLM_TRIAGE_PROVIDER=openai
# LLM_TRIAGE_MODEL=deepseek-chat
# LLM_TRIAGE_BASE_URL=https://api.deepseek.com
# LLM_TRIAGE_API_KEY=
# Analysis (news analysis / AnalystAgent):
# LLM_ANALYSIS_PROVIDER=openai
# LLM_ANALYSIS_MODEL=deepseek-reasoner
# LLM_ANALYSIS_BASE_URL=https://api.deepseek.com
# LLM_ANALYSIS_API_KEY=
# Narrative (narrative management / NarrativeManagerAgent):
# LLM_NARRATIVE_PROVIDER=openai
# LLM_NARRATIVE_MODEL=deepseek-reasoner
# LLM_NARRATIVE_BASE_URL=https://api.deepseek.com
# LLM_NARRATIVE_API_KEY=

# --- Narrative audit panel (v1.5; off by default) ---
# NARRATIVE_AUDIT_SEATS=0          # 0 关闭;1-3 个审计席位
# NARRATIVE_AUDIT_ROUNDS=1         # 1-3 轮(席位互看批判)
# 每席独立 key(默认推理模型;不填回退 LLM_*):
# LLM_AUDITOR_1_MODEL=deepseek-reasoner
# LLM_AUDITOR_1_API_KEY=
# LLM_AUDITOR_2_MODEL=deepseek-reasoner
# LLM_AUDITOR_2_API_KEY=
# LLM_AUDITOR_3_MODEL=deepseek-reasoner
# LLM_AUDITOR_3_API_KEY=
